<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTPS only for production — no cleartext -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Allow model download from storage backend -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">storage.phcai.in</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!-- Debug only: allow localhost for development -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
